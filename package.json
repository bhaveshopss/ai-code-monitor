{
  "name": "ai-code-monitor",
  "version": "1.4.1",
  "description": "Real-time monitoring dashboard for AI coding agents. One command to track tokens, costs, and latency for Claude Code, OpenCode, and more.",
  "bin": {
    "ai-code-monitor": "./dist/bin/cli.js"
  },
  "main": "./dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "dashboard",
    "assets"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/bin/cli.js"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "ai",
    "claude-code",
    "opencode",
    "monitoring",
    "llm",
    "tokens",
    "cost-tracking",
    "dashboard",
    "observability"
  ],
  "author": "Bhavesh Kumar Parmar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhaveshopss/ai-code-monitor"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "open": "^10.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
